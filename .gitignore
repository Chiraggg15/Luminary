# ════════════════════════════════════════════════════════════════════════════
#  .gitignore — AI Resume Generator FYP
#  Covers: Python/Flask backend + React/Vite frontend + OS files
# ════════════════════════════════════════════════════════════════════════════

# ── SECRETS (NEVER commit these) ─────────────────────────────────────────────
.env
*.env
.env.local
.env.production
.env.*.local

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
venv/
env/
ENV/
.venv/
.python-version

# pytest / coverage
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# ── Node / React / Vite ───────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Build output
frontend/dist/
frontend/build/
.cache/

# Vite
*.local

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.tmproj
*.sublime-project
*.sublime-workspace

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
*.pid

# ── MongoDB local data ────────────────────────────────────────────────────────
data/
dump/

# ── Misc ──────────────────────────────────────────────────────────────────────
*.bak
*.tmp
temp/
.temp/
